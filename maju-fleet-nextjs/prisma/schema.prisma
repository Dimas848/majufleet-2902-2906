generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String?  @default("maju123") // Kolom password manual wajib ada di sini
  phone     String?
  
  // Tambahan untuk Crew & Customer dari UI baru
  role      String   @default("customer") // "customer", "captain", "navigator", dll
  gender    String?  // "male", "female"
  age       Int?
  origin    String?
  address   String?
  status    String   @default("Active") // "Active", "Inactive"

  // ✅ SOLUSI: Pisah menjadi 2 relasi bernama agar Prisma tidak melontarkan error
  shipments          Shipment[] @relation("ShipmentOwner")
  captainedShipments Shipment[] @relation("ShipmentCaptain")
}

model Vessel {
  id           Int        @id @default(autoincrement())
  name         String
  capacity     Int
  
  // Tambahan untuk Vessel dari UI baru
  capacityUnit String     @default("TONNES") // "TONNES", "KG", "CBM"
  type         String?    // "Cargo", dll
  crewLead     String?
  status       String     @default("Active") // "Active", "Maintenance", "Docked"

  shipments    Shipment[]
}

model Port {
  id      Int        @id @default(autoincrement())
  name    String
  country String
  
  originShipments Shipment[] @relation("OriginPort")
  destShipments   Shipment[] @relation("DestPort")
}

model Invoice {
  id            Int      @id @default(autoincrement())
  invoiceNumber String   @unique // Contoh: INV-2026-0001
  amount        BigInt     // Total biaya dalam Rupiah
  status        String   @default("Pending") // "Pending" atau "Paid"
  createdAt     DateTime @default(now())
  
  // Relasi 1-to-1 ke Shipment
  shipmentId    Int      @unique
  shipment      Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model Shipment {
  id              Int            @id @default(autoincrement())
  receipt_number  String         @unique
  status          String         @default("PENDING")
  book_date       DateTime       @default(now())

  // Relasi Master
  userId          Int?
  // ✅ Diberi nama "ShipmentOwner" agar tidak bentrok dengan relasi kapten
  user            User?          @relation("ShipmentOwner", fields: [userId], references: [id])
  invoice         Invoice?
  // ✅ SINKRONISASI RELASI: Mengubah teks kapten biasa menjadi ID yang terikat ke tabel User
  captainId       Int?
  captain         User?          @relation("ShipmentCaptain", fields: [captainId], references: [id])

  vesselId        Int?
  vessel          Vessel?        @relation(fields: [vesselId], references: [id])
  originId        Int?
  origin          Port?          @relation("OriginPort", fields: [originId], references: [id])
  destId          Int?
  dest            Port?          @relation("DestPort", fields: [destId], references: [id])

  // Data Pengirim (Dari UI Form Baru)
  senderName      String?
  senderContact   String?
  senderEmail     String?
  senderAddress   String?
  senderCountry   String?
  senderCity      String?

  // Data Penerima (Dari UI Form Baru)
  recipientName    String?
  recipientContact String?
  recipientEmail   String?
  recipientAddress String?
  recipientCountry String?
  recipientCity    String?

  // Detail Kargo (Dari UI Form Baru)
  cargoDesc       String?
  weight          Float?
  weightUnit      String         @default("KG") // "KG", "TON", "LBS"
  dimensions      Float?
  category        String?

  items           ShipmentItem[]
  details         ShipmentDetail[]
}

model PackageType {
  id         Int    @id @default(autoincrement())
  name       String
  base_price Int
  items      ShipmentItem[]
}

model ShipmentItem {
  id            Int         @id @default(autoincrement())
  shipmentId    Int
  shipment      Shipment    @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  
  packageTypeId Int         // Cukup tulis satu kali saja di sini
  packageType   PackageType @relation(fields: [packageTypeId], references: [id])
  
  description   String?
  weight_kg     Float?
}

model ShipmentDetail {
  id          Int      @id @default(autoincrement())
  shipmentId  Int
  current_lat Float?
  current_lng Float?
  update_time DateTime @default(now())

  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
}

model AccessLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     // Kosong jika user tidak ditemukan
  name      String
  email     String
  role      String
  ipAddress String?
  location  String?
  device    String?
  status    String   // "SUCCESS", "FAILED_PASSWORD", "USER_NOT_FOUND"
  createdAt DateTime @default(now())
}